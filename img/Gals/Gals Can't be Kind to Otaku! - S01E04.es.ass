Dialogue: 0,0:00:04.57,0:00:10.20,Gen_Italics,Tele,0,0,0,,Una obra maestra de amor y lágrimas.\N"Amor Fantasma" ya llegó a los cines.
Dialogue: 0,0:00:09.03,0:00:10.99,Cart_A_Tre,CARTEL,0,0,0,,{\fad(688,0)\fs40\c&H4539B4&\3c&HFFFFFF&\pos(488,19.33)}Amor Fantasma\N{\fs25\c&H206BD5&}Y{\c&H2AA2DD&}a {\c&H38C9E0&}e{\c&H48B1E1&}n {\c&H4C9DDC&}ci{\c&H598DDC&}n{\c&H658ADC&}es
Dialogue: 0,0:00:11.53,0:00:15.24,Gen_Italics,Tele,0,0,0,,Somos la película #1 del momento\Npara ver con tu pareja.
Dialogue: 0,0:00:15.33,0:00:17.58,Gen_Italics,Mujer,0,0,0,,¡Qué manera de llorar!
Dialogue: 0,0:00:17.66,0:00:20.75,Gen_Italics,Hombre,0,0,0,,Se la pasó llorando\Ntoda la escena final.
Dialogue: 0,0:00:20.83,0:00:23.25,Gen_Italics,Señora,0,0,0,,Fue realmente maravillosa.
Dialogue: 0,0:00:23.92,0:00:26.97,Gen_Italics,Señor,0,0,0,,Inguar Josephlin sí que sabe\Nhacer películas.
Dialogue: 0,0:00:27.05,0:00:30.24,Gen_Italics,Señor,0,0,0,,La protagonista, Amanda O'Neill,\Nes realmente hermosa.
Dialogue: 0,0:00:32.30,0:00:35.64,Gen_Main,Ijichi,0,0,0,,¿Quieres tener\Nuna cita después de clases?
Dialogue: 0,0:00:39.77,0:00:43.77,Gen_Main,Ijichi/Seo,0,0,0,,-¡Amane! Buenas.\N-Buenos días.
Dialogue: 0,0:00:44.02,0:00:45.45,Gen_Main,Amane,0,0,0,,Buen día.
Dialogue: 0,0:00:45.86,0:00:48.04,Gen_Main,Amane,0,0,0,,Este, chicos…
Dialogue: 0,0:00:49.07,0:00:53.66,Gen_Main,Amane,0,0,0,,Ayer habían dicho\Nque iban a tener una cita, ¿no?
Dialogue: 0,0:00:54.37,0:00:58.04,Gen_Main,Amane,0,0,0,,¿Puedo preguntar… qué película vieron?
Dialogue: 7,0:00:58.20,0:01:01.42,Gen_Italics,Seo/Ijichi/Amane,0,0,0,,-"Zombis vs. Tiburón".\N-¡¿"Zombis vs. Tiburón"?!
Dialogue: 0,0:00:58.25,0:01:01.41,Cart_A_Tre,CARTEL,0,0,0,,{\c&HC874B8&\3c&H4D434F&\4c&H3F28DB&\shad2\fad(183,0)\fs25\pos(524.67,131.33)}Zombis {\c&HF5F7F7&\3c&H553851&\fntimes new roman\4c&H8B91B7&}VS {\c&HE4C758&\3c&H4D434F&\4c&H3F28DB&\xshad-2\t(rebuchet)}Tiburón
Dialogue: 0,0:01:01.54,0:01:03.63,Gen_Main,Ijichi,0,0,0,,Estuvo muy buena.
Dialogue: 0,0:01:03.71,0:01:06.17,Gen_Main,Amane,0,0,0,,¿Cómo pueden ver eso en una cita?
Dialogue: 0,0:01:06.84,0:01:10.07,Gen_Italics,Amane,0,0,0,,Bueno, no hicieron nada\Nque parezca una cita.
Dialogue: 0,0:01:10.13,0:01:11.93,Gen_Italics,Amane,0,0,0,,Menos mal, me alegro.
Dialogue: 0,0:01:12.34,0:01:15.43,Gen_Italics,Amane,0,0,0,,¡Momento! ¡¿Por qué me tranquiliza?!
Dialogue: 0,0:01:15.51,0:01:17.93,Gen_Italics,Amane,0,0,0,,No es como si me importara lo que hacen…
Dialogue: 0,0:01:18.02,0:01:20.81,Gen_Main,Ijichi,0,0,0,,Cierto, también usamos\Nla cabina de fotos.
Dialogue: 0,0:01:21.52,0:01:24.73,Gen_Italics,Amane,0,0,0,,¡Ahí está, lo sabía!\N¡Hicieron algo típico de una cita!
Dialogue: 0,0:01:24.81,0:01:28.94,Gen_Italics,Amane,0,0,0,,Pero ¿y si posaron entrelazando\Nlos brazos? ¿O algo aún peor?
Dialogue: 0,0:01:29.44,0:01:30.69,Gen_Main,Ijichi,0,0,0,,Aquí las tengo.
Dialogue: 0,0:01:30.69,0:01:33.32,Cart_A_Tre,CARTEL,0,0,0,,{\c&HF862C3&\3c&H500178&\fad(0,0)\fs40\frz18.16\move(256,10.67,103.34,57.33,943,1151)}Zombis {\c&HF5F7F7&\fntimes new roman}VS {\c&HBBEB20&\t(rebuchet)}Tiburón
Dialogue: 0,0:01:31.65,0:01:33.32,Gen_Italics,Amane,0,0,0,,¡"Zombis vs. Tiburón"!
Dialogue: 0,0:01:33.74,0:01:35.32,Gen_Main,Amane,0,0,0,,Me sorprenden.
Dialogue: 0,0:01:35.41,0:01:37.80,Gen_Main,Ijichi,0,0,0,,Me quedaron bonitas, ¿no?
Dialogue: 0,0:01:38.41,0:01:40.66,Gen_Main,Seo,0,0,0,,Ijichi, se te cayó…
Dialogue: 0,0:01:44.71,0:01:46.00,Gen_Italics,Seo,0,0,0,,Un momento…
Dialogue: 0,0:01:46.29,0:01:47.75,Gen_Italics,Seo,0,0,0,,¡¿Quién era ese?!
Dialogue: 0,0:03:15.09,0:03:16.67,Cart_A_Tre,CARTEL,0,0,0,,{\c&H32E9C2&\3c&HF9F9F9&\fad(0,0)\fs40\blur2\pos(333.33,41.33)}Gals {\c&HB39F9D&}Can't {\c&HB489F4&}Be Kind {\c&HB39F9D&}to {\c&HE9BF8B&}Otaku{\c&HB39F9D&}!?
Dialogue: 0,0:03:18.22,0:03:23.09,Cart_A_Tre,CARTEL,0,0,0,,{\fad(478,0)\an3\c&H32E9C2&\fs18\3c&HFFFFFF&\pos(598,301.34)}04:00    {\c&HB992EF&}Vamos {\c&HEAC391&}al {\c&HB39F9D&}karaoke
Dialogue: 0,0:03:19.76,0:03:23.31,Gen_Main_Up,Ijichi,0,0,0,,Creo que tengo que ir al baño…\N¡Adiosín!
Dialogue: 0,0:03:23.39,0:03:24.73,Gen_Main,Seo,0,0,0,,¡Ijichi!
Dialogue: 0,0:03:25.81,0:03:28.23,Gen_Main,Seo,0,0,0,,Esa forma de actuar…\NNo puede ser.
Dialogue: 0,0:03:28.73,0:03:30.11,Gen_Main,Seo,0,0,0,,¡¿Es su novio?!
Dialogue: 0,0:03:30.27,0:03:31.27,Cart_A_Tre,CARTEL,0,0,0,,{\fad(440,500)\c&H2DEEF7&\3c&H18A4E7&\fncomic sans ms\fs80\an2\pos(301.34,60.67)}giro giro
Dialogue: 0,0:03:30.86,0:03:34.94,Gen_Italics,Seo,0,0,0,,Me dijo que no le interesaba el amor,\Npero ¿sí que tenía a alguien?
Dialogue: 0,0:03:31.52,0:03:32.52,Cart_A_Tre,CARTEL,0,0,0,,{\fad(440,500)\c&H2DEEF7&\3c&H18A4E7&\fncomic sans ms\fs80\an2\pos(301.34,60.67)}giro giro
Dialogue: 0,0:03:32.78,0:03:33.73,Cart_A_Tre,CARTEL,0,0,0,,{\fad(470,470)\c&H2DEEF7&\3c&H18A4E7&\fncomic sans ms\fs80\an2\pos(301.34,60.67)}giro giro
Dialogue: 0,0:03:34.03,0:03:35.03,Cart_A_Tre,CARTEL,0,0,0,,{\fad(470,500)\c&H2DEEF7&\3c&H18A4E7&\fncomic sans ms\fs80\an2\pos(301.34,60.67)}giro giro
Dialogue: 0,0:03:35.03,0:03:38.61,Gen_Italics,Seo,0,0,0,,¿Y encima tiene citas conmigo?\N¿Está bien hacer eso?
Dialogue: 0,0:03:35.28,0:03:36.28,Cart_A_Tre,CARTEL,0,0,0,,{\fad(500,500)\c&H2DEEF7&\3c&H18A4E7&\fncomic sans ms\fs80\an2\pos(301.34,60.67)}giro giro
Dialogue: 0,0:03:36.53,0:03:37.49,Cart_A_Tre,CARTEL,0,0,0,,{\fad(478,440)\c&H2DEEF7&\3c&H18A4E7&\fncomic sans ms\fs80\an2\pos(301.34,60.67)}giro giro
Dialogue: 0,0:03:37.78,0:03:38.61,Cart_A_Tre,CARTEL,0,0,0,,{\fad(478,400)\c&H2DEEF7&\3c&H18A4E7&\fncomic sans ms\fs80\an2\pos(301.34,60.67)}gira gira
Dialogue: 0,0:03:39.20,0:03:41.37,Gen_Main,Amane,0,0,0,,Ijichi tiene un hermano mayor…
Dialogue: 0,0:03:41.45,0:03:43.24,Gen_Main,Seo,0,0,0,,Entonces, debe ser él.
Dialogue: 0,0:03:43.58,0:03:46.08,Gen_Main,Amane,0,0,0,,Pero nunca había visto a ese hombre.
Dialogue: 0,0:03:46.16,0:03:48.03,Gen_Main,Amane,0,0,0,,Y sé que no es su padre.
Dialogue: 0,0:03:49.79,0:03:52.25,Gen_Main,Amane,0,0,0,,Que él sea mayor\Nno es un gran problema,
Dialogue: 0,0:03:52.34,0:03:55.84,Gen_Main,Amane,0,0,0,,pero parecía ser mucho,\Nmucho más grande.
Dialogue: 0,0:03:55.92,0:03:59.30,Gen_Main,Amane,0,0,0,,Si resulta que tiene un {\i1}sugar daddy{\i0}…
Dialogue: 0,0:03:59.39,0:04:02.35,Gen_Main,Seo,0,0,0,,¡¿Un {\i1}sugar{\i0}…?!\NMe costaría creerlo de Ijichi.
Dialogue: 0,0:04:02.43,0:04:04.52,Gen_Main,Amane,0,0,0,,¡Justo por eso estoy preocupada!
Dialogue: 0,0:04:05.18,0:04:09.10,Gen_Main,Amane,0,0,0,,Si se apuró tanto\Npara esconderla, es por algo,
Dialogue: 0,0:04:09.19,0:04:12.31,Gen_Main,Amane,0,0,0,,pero ¿nos corresponde\Na nosotros meternos en su vida?
Dialogue: 0,0:04:12.90,0:04:14.78,Gen_Main,Seo,0,0,0,,Con más razón debemos hacerlo.
Dialogue: 0,0:04:15.15,0:04:18.40,Gen_Main,Seo,0,0,0,,Las dos son amigas\Nmuy importantes para mí.
Dialogue: 0,0:04:18.61,0:04:21.54,Gen_Main,Seo,0,0,0,,Si mis amigas tienen problemas,\Nyo quiero ayudar.
Dialogue: 0,0:04:22.62,0:04:23.66,Gen_Main,Amane,0,0,0,,¡De acuerdo!
Dialogue: 0,0:04:23.91,0:04:25.41,Cart_A_Tre,CARTEL,0,0,0,,{\fad(228,0)\c&H282926&\3c&HE3E3E3&\fncomic sans ms\an7\fs30\pos(10,9.33)}¡Comité para cuidar a Ijichi!
Dialogue: 0,0:04:29.16,0:04:29.87,Cart_A_Tre,CARTEL,0,0,0,,{\fad(0,0)\c&H282926&\3c&HE3E3E3&\fncomic sans ms\fs22\move(516.01,194.67,516.01,356.67,25,692)}¡Te apoyamos Ijichi contigo!
Dialogue: 0,0:04:29.71,0:04:32.17,Gen_Main,Amane,0,0,0,,¡Vamos a apoyar a Ijichi!
Dialogue: 0,0:04:32.33,0:04:34.21,Gen_Main,Ijichi,0,0,0,,Carajo.
Dialogue: 0,0:04:35.46,0:04:37.26,Gen_Main,Ijichi,0,0,0,,Perdón por ocultarlo.
Dialogue: 0,0:04:37.34,0:04:40.68,Gen_Main,Ijichi,0,0,0,,El de la foto de recién era…
Dialogue: 0,0:04:40.76,0:04:43.01,Gen_Main,Ijichi,0,0,0,,Mi hermano mayor.
Dialogue: 0,0:04:43.10,0:04:46.29,Gen_Main,Ijichi,0,0,0,,Siempre fui muy apegada\Ncomo su hermanita,
Dialogue: 0,0:04:46.39,0:04:48.93,Gen_Main,Ijichi,0,0,0,,pero entiendo que pueda verse raro…
Dialogue: 0,0:04:49.06,0:04:53.44,Gen_Main,Amane/Seo,0,0,0,,-¡Menos mal!\N-¡¿Les pareció bien?!
Dialogue: 0,0:04:53.52,0:04:57.57,Gen_Main,Seo,0,0,0,,Por cierto,\N¿cuántos hermanos tienes, Ijichi?
Dialogue: 0,0:04:57.69,0:04:59.95,Gen_Main,Ijichi,0,0,0,,Conmigo somos cinco hermanos.
Dialogue: 0,0:05:00.03,0:05:03.70,Gen_Main,Ijichi,0,0,0,,El mayor tiene 25 y el menor, 7.
Dialogue: 0,0:05:03.82,0:05:05.74,Gen_Main,Amane,0,0,0,,¿18 años de diferencia?
Dialogue: 0,0:05:05.83,0:05:07.45,Gen_Main,Seo,0,0,0,,Ahora entiendo.
Dialogue: 0,0:05:07.54,0:05:11.71,Gen_Main,Mizuki,0,0,0,,¡Amane! Nos toca ser encargadas.\NHay que buscar al profe.
Dialogue: 0,0:05:11.83,0:05:13.71,Gen_Main,Amane,0,0,0,,Lo siento, ya voy.
Dialogue: 0,0:05:15.29,0:05:16.96,Gen_Main,Amane/Ijichi,0,0,0,,Una cosa, Ijichi…
Dialogue: 0,0:05:17.96,0:05:20.09,Gen_Main,Amane,0,0,0,,Si llega a pasarte algo, cuéntanos.
Dialogue: 0,0:05:20.17,0:05:23.51,Gen_Main,Amane,0,0,0,,También eres muy importante para mí.
Dialogue: 0,0:05:25.18,0:05:29.02,Gen_Main,Ijichi,0,0,0,,Lo haré, muchas gracias.
Dialogue: 0,0:05:31.06,0:05:34.06,Gen_Main,Ijichi,0,0,0,,¡Amane es increíble!
Dialogue: 0,0:05:34.15,0:05:36.52,Gen_Main,Ijichi,0,0,0,,Y casi me enamoro de ti, Otaku.
Dialogue: 0,0:05:36.61,0:05:39.28,Gen_Main,Seo,0,0,0,,¡¿De qué rayos estás hablando?!
Dialogue: 0,0:05:39.53,0:05:40.61,Gen_Main,Seo,0,0,0,,Pero…
Dialogue: 0,0:05:41.15,0:05:45.99,Gen_Main,Seo,0,0,0,,es muy lindo tener amigas\Ncon quienes abrirte sin miedo.
Dialogue: 0,0:05:48.79,0:05:51.86,Gen_Italics,Ijichi,0,0,0,,Otra vez diciendo esas cosas…
Dialogue: 0,0:05:52.37,0:05:55.87,Cart_A_Tre,CARTEL,0,0,0,,{\fncomic sans ms\fs18\blur3\c&H44FFF0&\3c&HA77544&\pos(479.33,239.34)\frz5.43}Kakeru
Dialogue: 0,0:05:52.37,0:05:55.87,Cart_A_Tre,CARTEL,0,0,0,,{\fncomic sans ms\fs18\blur3\c&H44FFF0&\3c&HA77544&\frz351.9\pos(148.66,275.33)}Hibiki
Dialogue: 0,0:05:52.37,0:05:55.87,Cart_A_Tre,CARTEL,0,0,0,,{\fncomic sans ms\fs28\blur3\c&H44FFF0&\3c&HA77544&\pos(308.66,47.34)}Kotoko
Dialogue: 0,0:05:52.37,0:05:55.87,Cart_A_Tre,CARTEL,0,0,0,,{\fncomic sans ms\fs12\blur3\c&H44FFF0&\3c&HA77544&\frz14.64\pos(92.67,179.33)}Los más duros
Dialogue: 0,0:05:53.46,0:05:54.80,Gen_Main,Ijichi/Hibiki/Kakeru,0,0,0,,Otagal.
Dialogue: 0,0:05:56.63,0:05:59.80,Gen_Main,Profesor,0,0,0,,Mañana es el torneo\Nde deportes de pelota.
Dialogue: 0,0:05:59.88,0:06:04.98,Gen_Main,Profesor,0,0,0,,Asegúrense de confirmar\Nen qué equipo jugará cada uno.
Dialogue: 0,0:06:03.63,0:06:06.64,Cart_A_Tre,CARTEL,0,0,0,,{\t(21,400,\3c&H627460&\c&HDDE2DB&)\3c&H697C67&\c&HC8CFC7&)\fncomic sans ms\move(364,168,414.67,168)}Kotoko Ijichi
Dialogue: 0,0:06:03.63,0:06:06.64,Cart_A_Tre,CARTEL,0,0,0,,{\3c&H5B6D5A&\c&HE8EFE8&\fs22\fncomic sans ms\t(21,400,\c&H5C5F5C&\3c&H2C332B&)\b0\move(530.67,111.33,581.34,111.33)}Ping-pong
Dialogue: 0,0:06:03.63,0:06:06.64,Cart_A_Tre,CARTEL,0,0,0,,{\3c&H697C67&\c&HE8EFE8&\fs22\fncomic sans ms\t(21,400,\c&H5C5F5C&\3c&H2C332B&)\b0\move(296.67,111.33,347.34,111.33)}Béisbol
Dialogue: 0,0:06:03.63,0:06:06.64,Cart_A_Tre,CARTEL,0,0,0,,{\t(21,400,\3c&H627460&\c&HDDE2DB&)\3c&H697C67&\c&HC8CFC7&)\fncomic sans ms\move(148.01,162,198.68,162)}Takuya Seo
Dialogue: 0,0:06:06.72,0:06:09.36,Gen_Main,Ijichi,0,0,0,,Ay, qué horror…
Dialogue: 0,0:06:09.43,0:06:11.77,Gen_Main,Ijichi,0,0,0,,Doy vergüenza\Nen los deportes de pelota.
Dialogue: 0,0:06:11.85,0:06:14.90,Gen_Main,Seo,0,0,0,,Yo doy asco en los deportes, en general.
Dialogue: 0,0:06:17.40,0:06:20.36,Gen_Main,Amane,0,0,0,,Por fin llegó mi momento de brillar.
Dialogue: 0,0:06:20.44,0:06:21.94,Gen_Main,Seo,0,0,0,,¿Amane?
Dialogue: 0,0:06:22.36,0:06:25.07,Gen_Main,Seo,0,0,0,,No hace falta que te exijas demasiado.
Dialogue: 0,0:06:25.24,0:06:28.91,Gen_Main,Amane,0,0,0,,Otaku, siento que crees\Nque soy una inútil.
Dialogue: 0,0:06:29.28,0:06:33.16,Gen_Main,Amane,0,0,0,,Bueno, mañana te sorprenderá\Nel partido de básquet femenino.
Dialogue: 0,0:06:33.25,0:06:34.58,Gen_Main,Amane,0,0,0,,Vengan a verme.
Dialogue: 0,0:06:50.85,0:06:53.23,Gen_Main,Todos,0,0,0,,¡Sí!
Dialogue: 0,0:06:53.31,0:06:55.38,Gen_Main,Chico 1,0,0,0,,¡Genial! ¿Viste a esa de primero?
Dialogue: 0,0:06:55.48,0:06:58.66,Gen_Main,Chico 2/Compañera 1,0,0,0,,-¿No conocías a Kei Amane?\N-¡Bien hecho, Amane!
Dialogue: 0,0:06:58.73,0:06:59.73,Gen_Main,Compañera 2,0,0,0,,¡Destrózalas!
Dialogue: 0,0:06:59.90,0:07:02.11,Gen_Italics,Seo,0,0,0,,No sabía que fuera tan buena.
Dialogue: 0,0:07:00.82,0:07:02.69,Gen_Main_Up,Chico 3/Chico 4,0,0,0,,¡Así se hace, Amane!\N-¡Tú puedes!
Dialogue: 0,0:07:02.78,0:07:04.74,Gen_Italics,Seo,0,0,0,,Y sí que es una chica popular.
Dialogue: 0,0:07:02.99,0:07:04.74,Gen_Main_Up,Chica 1,0,0,0,,¡Eres la mejor, reina Amane!
Dialogue: 0,0:07:09.03,0:07:11.45,Gen_Main,Shion,0,0,0,,¡Bien hecho! Vamos primeras.
Dialogue: 0,0:07:11.54,0:07:13.25,Gen_Main,Amane,0,0,0,,Muchas gracias.
Dialogue: 0,0:07:13.37,0:07:18.79,Gen_Main,Chica 2,0,0,0,,Oye, ¿sabías que Kei Amane\Nllegó a los nacionales en secundaria?
Dialogue: 0,0:07:18.88,0:07:20.34,Gen_Main,Chica 3,0,0,0,,Es impresionante.
Dialogue: 0,0:07:20.42,0:07:23.05,Gen_Main,Chica 2,0,0,0,,La apodaban "Máscara de hierro".
Dialogue: 0,0:07:23.84,0:07:28.30,Gen_Main,Chica 1,0,0,0,,Dicen que nunca sonríe,\Nni aunque haya hecho una gran jugada.
Dialogue: 0,0:07:29.05,0:07:31.51,Gen_Italics,Seo,0,0,0,,Aunque por dentro seguro está contenta.
Dialogue: 0,0:07:31.76,0:07:35.98,Gen_Italics,Seo,0,0,0,,Bueno, Amane suele parecer inaccesible.
Dialogue: 0,0:07:36.06,0:07:39.40,Gen_Italics,Seo,0,0,0,,Como es tan buena en esto,\Na lo mejor la malinterpretan.
Dialogue: 0,0:07:40.90,0:07:43.40,Gen_Main,Chico 5/Chico 6,0,0,0,,-¡Ánimo!\N-¡Gánales!
Dialogue: 0,0:07:43.65,0:07:45.81,Gen_Main,Shion,0,0,0,,Vamos a jugar, Amane.
Dialogue: 0,0:07:45.90,0:07:47.42,Gen_Main,Amane,0,0,0,,Enseguida.
Dialogue: 0,0:07:51.33,0:07:52.33,Gen_Main,Chica/Público,0,0,0,,-¡Ánimo!\N-¡Venga!
Dialogue: 0,0:07:52.41,0:07:53.87,Gen_Main,Seo,0,0,0,,¡Amane!
Dialogue: 0,0:07:54.08,0:07:55.62,Gen_Main,Seo,0,0,0,,¡Tú puedes!
Dialogue: 0,0:08:03.50,0:08:05.01,Gen_Main,Chica 4,0,0,0,,¡¿Sonrió?!
Dialogue: 0,0:08:05.09,0:08:07.13,Gen_Main,Chica 5/Chica 6,0,0,0,,-¡Qué hermosa!\N-Me enamoré.
Dialogue: 0,0:08:07.22,0:08:08.86,Gen_Main,Chica 4,0,0,0,,¡Acaba de sonreírme!
Dialogue: 0,0:08:08.93,0:08:10.39,Gen_Main,Chica 5,0,0,0,,¡Tarada, me sonrió a mí!
Dialogue: 0,0:08:11.68,0:08:13.64,Gen_Italics,Amane,0,0,0,,Voy a tener que lucirme.
Dialogue: 0,0:08:19.81,0:08:22.77,Gen_Italics,Amane,0,0,0,,No soy inteligente como Ijichi.
Dialogue: 0,0:08:22.86,0:08:24.48,Gen_Italics,Amane,0,0,0,,Ni tan simpática.
Dialogue: 0,0:08:24.61,0:08:26.94,Gen_Italics,Amane,0,0,0,,Tengo que mostrar en qué soy buena.
Dialogue: 0,0:08:27.36,0:08:28.82,Gen_Italics,Amane,0,0,0,,¡Debo hacerlo!
Dialogue: 0,0:08:29.95,0:08:33.41,Gen_Italics,Amane,0,0,0,,Y entonces, quizás, Otaku al fin…
Dialogue: 0,0:08:35.24,0:08:36.33,Gen_Italics,Amane,0,0,0,,¿Eh?
Dialogue: 0,0:08:36.45,0:08:39.08,Gen_Italics,Amane,0,0,0,,¿Por qué estoy pensando en él?
Dialogue: 0,0:08:45.50,0:08:47.34,Gen_Italics,Amane,0,0,0,,No, ya sé lo que pasa.
Dialogue: 0,0:08:47.42,0:08:49.72,Gen_Italics,Amane,0,0,0,,Solo quiero vengarme de él.
Dialogue: 0,0:08:54.22,0:08:58.73,Gen_Italics,Amane,0,0,0,,Me ganó en los exámenes,\Nasí que le ganaré en deportes.
Dialogue: 0,0:08:58.81,0:09:01.40,Gen_Italics,Amane,0,0,0,,No es como si tuviera…
Dialogue: 0,0:09:02.44,0:09:04.15,Gen_Italics,Amane,0,0,0,,sentimientos por él ni nada.
Dialogue: 0,0:09:10.82,0:09:12.88,Gen_Main,Ai,0,0,0,,¡Muy buen tiro, Amane!
Dialogue: 0,0:09:12.95,0:09:14.37,Gen_Main,Mai,0,0,0,,¡Vamos a ganar!
Dialogue: 0,0:09:14.45,0:09:16.45,Gen_Main,Mii,0,0,0,,Estabas muy comprometida.
Dialogue: 0,0:09:16.54,0:09:18.00,Gen_Main,Shion,0,0,0,,Eres increíble, Amane.
Dialogue: 0,0:09:18.16,0:09:20.10,Gen_Main,Shion,0,0,0,,Se nota que te gusta mucho…
Dialogue: 0,0:09:20.83,0:09:24.38,Gen_Main,Amane,0,0,0,,¡Que no! No es que lo odie,\Npero decir que me gusta mucho…
Dialogue: 0,0:09:24.46,0:09:25.63,Gen_Main,Shion,0,0,0,,¡El básquet!
Dialogue: 0,0:09:27.84,0:09:31.79,Gen_Main,Amane,0,0,0,,Ah, el básquet. Sí, claro,\Nme gusta bastante…
Dialogue: 0,0:09:31.88,0:09:35.26,Gen_Main,Shion,0,0,0,,¡Me imaginaba!\N¡Deberías unirte al equipo!
Dialogue: 0,0:09:35.35,0:09:37.31,Gen_Main,Ai,0,0,0,,¡Contigo seríamos invencibles!
Dialogue: 0,0:09:37.39,0:09:39.31,Gen_Main,Shion,0,0,0,,¡Nadie nos ganaría!
