Dialogue: 0,0:00:59.33,0:01:01.95,Default,,0,0,0,,Solo las creaciones fallidas\Nde los que vinieron antes
Dialogue: 0,0:01:01.95,0:01:04.79,Default,,0,0,0,,Algunos elementos rebeldes, podridos hasta la médula
Dialogue: 0,0:01:04.79,0:01:07.21,Default,,0,0,0,,Más allá de la cerca de alambre,\Nun mundo de diseño elegante
Dialogue: 0,0:01:07.21,0:01:09.67,Default,,0,0,0,,Lo miré fijamente,\Nun secreto que solo era mío
Dialogue: 0,0:01:09.67,0:01:11.96,Default,,0,0,0,,Dentro del mundo perfecto\Nque alguien más diseñó
Dialogue: 0,0:01:11.96,0:01:14.47,Default,,0,0,0,,Si éramos diferentes,\Nsiempre nos dejaban atrás
Dialogue: 0,0:01:14.47,0:01:16.93,Default,,0,0,0,,En un mundo gentil para que todos lo contemplen
Dialogue: 0,0:01:16.93,0:01:19.85,Default,,0,0,0,,Alguien desconocido lloraba de agonía
Dialogue: 0,0:01:19.85,0:01:21.85,Default,,0,0,0,,Solo una multitud riendo,\Nun rebaño sin mente de cuervos,
Dialogue: 0,0:01:21.85,0:01:23.81,Default,,0,0,0,,Siempre diciendo "NO"\Na cosas que nadie conoce
Dialogue: 0,0:01:23.81,0:01:26.31,Default,,0,0,0,,Con valores y con normalidad posan
Dialogue: 0,0:01:26.31,0:01:27.77,Default,,0,0,0,,Armados con todas sus teorías, supongo
Dialogue: 0,0:01:27.77,0:01:28.81,Default,,0,0,0,,Y luego nos llaman inútiles pros
